# Aubric AML — local dev env template. Copy to .env and fill in.
# AML_BACKEND controls storage: sqlite (default, no setup) | tidb (production path).
AML_BACKEND=sqlite
AML_SQLITE_PATH=./data/aml_memory.sqlite

# Required only when AML_BACKEND=tidb. TiDB Cloud Serverless DSN.
# Format: mysql://USER:PASSWORD@HOST:4000/DATABASE
# Get one at: https://tidbcloud.com (Serverless tier is free).
DATABASE_URL=

# Optional. Drives actual sandbox execution for the update loop.
# Without this, the update cycle falls back to local Python (demo still works).
DAYTONA_API_KEY=

# Optional. Drives real adversarial OSINT lookups during the update cycle.
# Without this, the cycle still runs; no Exa hits surface.
EXA_API_KEY=

# Optional. Where audit bundles are written. Default: ./data
AML_AUDIT_DIR=./data
